{
  "$schema": "https://opencode.ai/theme.json",
  "defs": {
    "purple": "#af87ff",
    "blue": "#3399ff",
    "orange": "#ff9933",
    "lightBlue": "#99ccff",
    "teal": "#00cccc",
    "profBlue": "#6a9bcc",
    "fg": "#f8f8f2",
    "muted": "#999999",
    "subtle": "#505050",
    "bg": "#1a1a1a",
    "bgPanel": "#222222",
    "bgElement": "#2c323e",
    "bgUser": "#373737",
    "monokaiPink": "#f92672",
    "monokaiGreen": "#a6e22e",
    "monokaiYellow": "#e6db74",
    "monokaiCyan": "#66d9ef",
    "monokaiPurple": "#ae81ff",
    "monokaiComment": "#75715e",
    "monokaiOrange": "#fd971f",
    "ccError": "#ff6666",
    "ccWarning": "#ffcc00",
    "lightPurple": "#7b5bb6",
    "lightBlue2": "#2277cc",
    "lightOrange": "#cc7722",
    "lightGreen": "#4d8a0f",
    "lightRed": "#c4173e",
    "lightYellow": "#b0851f",
    "lightCyan": "#318795",
    "lightMuted": "#666666",
    "lightComment": "#75715e"
  },
  "theme": {
    "primary": {
      "dark": "purple",
      "light": "lightPurple"
    },
    "secondary": {
      "dark": "profBlue",
      "light": "lightBlue2"
    },
    "accent": {
      "dark": "orange",
      "light": "lightOrange"
    },
    "error": {
      "dark": "ccError",
      "light": "lightRed"
    },
    "warning": {
      "dark": "ccWarning",
      "light": "lightYellow"
    },
    "success": {
      "dark": "monokaiGreen",
      "light": "lightGreen"
    },
    "info": {
      "dark": "lightBlue",
      "light": "lightCyan"
    },
    "text": {
      "dark": "fg",
      "light": "#1a1a1a"
    },
    "textMuted": {
      "dark": "muted",
      "light": "lightMuted"
    },
    "background": {
      "dark": "bg",
      "light": "#ffffff"
    },
    "backgroundPanel": {
      "dark": "bgPanel",
      "light": "#f5f5f5"
    },
    "backgroundElement": {
      "dark": "bgElement",
      "light": "#ebebeb"
    },
    "border": {
      "dark": "subtle",
      "light": "#cccccc"
    },
    "borderActive": {
      "dark": "blue",
      "light": "lightBlue2"
    },
    "borderSubtle": {
      "dark": "bgUser",
      "light": "#e0e0e0"
    },
    "diffAdded": {
      "dark": "monokaiGreen",
      "light": "lightGreen"
    },
    "diffRemoved": {
      "dark": "monokaiPink",
      "light": "lightRed"
    },
    "diffContext": {
      "dark": "monokaiComment",
      "light": "lightComment"
    },
    "diffHunkHeader": {
      "dark": "monokaiComment",
      "light": "lightComment"
    },
    "diffHighlightAdded": {
      "dark": "monokaiGreen",
      "light": "lightGreen"
    },
    "diffHighlightRemoved": {
      "dark": "monokaiPink",
      "light": "lightRed"
    },
    "diffAddedBg": {
      "dark": "#1a2e1a",
      "light": "#e0ffe0"
    },
    "diffRemovedBg": {
      "dark": "#3a1a1a",
      "light": "#ffe0e0"
    },
    "diffContextBg": {
      "dark": "bgPanel",
      "light": "#f5f5f5"
    },
    "diffLineNumber": {
      "dark": "bgElement",
      "light": "#cccccc"
    },
    "diffAddedLineNumberBg": {
      "dark": "#1a2e1a",
      "light": "#e0ffe0"
    },
    "diffRemovedLineNumberBg": {
      "dark": "#3a1a1a",
      "light": "#ffe0e0"
    },
    "markdownText": {
      "dark": "fg",
      "light": "#1a1a1a"
    },
    "markdownHeading": {
      "dark": "purple",
      "light": "lightPurple"
    },
    "markdownLink": {
      "dark": "monokaiCyan",
      "light": "lightCyan"
    },
    "markdownLinkText": {
      "dark": "monokaiPink",
      "light": "lightRed"
    },
    "markdownCode": {
      "dark": "monokaiGreen",
      "light": "lightGreen"
    },
    "markdownBlockQuote": {
      "dark": "monokaiComment",
      "light": "lightComment"
    },
    "markdownEmph": {
      "dark": "monokaiYellow",
      "light": "lightYellow"
    },
    "markdownStrong": {
      "dark": "monokaiOrange",
      "light": "lightOrange"
    },
    "markdownHorizontalRule": {
      "dark": "muted",
      "light": "lightMuted"
    },
    "markdownListItem": {
      "dark": "monokaiCyan",
      "light": "lightCyan"
    },
    "markdownListEnumeration": {
      "dark": "monokaiPurple",
      "light": "lightPurple"
    },
    "markdownImage": {
      "dark": "monokaiCyan",
      "light": "lightCyan"
    },
    "markdownImageText": {
      "dark": "monokaiPink",
      "light": "lightRed"
    },
    "markdownCodeBlock": {
      "dark": "fg",
      "light": "#1a1a1a"
    },
    "syntaxComment": {
      "dark": "monokaiComment",
      "light": "lightComment"
    },
    "syntaxKeyword": {
      "dark": "monokaiPink",
      "light": "lightRed"
    },
    "syntaxFunction": {
      "dark": "monokaiGreen",
      "light": "lightGreen"
    },
    "syntaxVariable": {
      "dark": "fg",
      "light": "#1a1a1a"
    },
    "syntaxString": {
      "dark": "monokaiYellow",
      "light": "lightYellow"
    },
    "syntaxNumber": {
      "dark": "monokaiPurple",
      "light": "lightPurple"
    },
    "syntaxType": {
      "dark": "monokaiCyan",
      "light": "lightCyan"
    },
    "syntaxOperator": {
      "dark": "monokaiPink",
      "light": "lightRed"
    },
    "syntaxPunctuation": {
      "dark": "fg",
      "light": "#1a1a1a"
    }
  }
}
