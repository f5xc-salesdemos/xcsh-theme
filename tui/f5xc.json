{
  "$schema": "https://opencode.ai/theme.json",
  "defs": {
    "f5Red": "#e4002b",
    "f5RedL2": "#f06680",
    "f5RedL3": "#a70020",
    "tangerine": "#f29a36",
    "tangerineL2": "#ffbd61",
    "tangerineL3": "#a35700",
    "river": "#0e41aa",
    "riverL2": "#6e8dcc",
    "riverL3": "#0b3180",
    "jade": "#009639",
    "jadeL2": "#66c088",
    "jadeL3": "#00712b",
    "eggplant": "#62228b",
    "eggplantL2": "#9c59c9",
    "eggplantL3": "#822cb8",
    "bay": "#0072b0",
    "bayL1": "#b2d7eb",
    "bayL2": "#66afd7",
    "bayL3": "#005c8d",
    "whiteL1": "#faf9f7",
    "whiteL2": "#f5f5f5",
    "whiteL3": "#e6e6e6",
    "whiteL4": "#cccccc",
    "blackL1": "#999999",
    "blackL2": "#666666",
    "blackL3": "#343434",
    "blackL4": "#222222"
  },
  "theme": {
    "primary": {
      "dark": "eggplantL2",
      "light": "eggplant"
    },
    "secondary": {
      "dark": "riverL2",
      "light": "river"
    },
    "accent": {
      "dark": "tangerine",
      "light": "tangerineL3"
    },
    "error": {
      "dark": "f5RedL2",
      "light": "f5RedL3"
    },
    "warning": {
      "dark": "tangerine",
      "light": "tangerineL3"
    },
    "success": {
      "dark": "jadeL2",
      "light": "jadeL3"
    },
    "info": {
      "dark": "bayL1",
      "light": "bayL3"
    },
    "text": {
      "dark": "whiteL1",
      "light": "#1a1a1a"
    },
    "textMuted": {
      "dark": "blackL1",
      "light": "blackL2"
    },
    "background": {
      "dark": "blackL4",
      "light": "#ffffff"
    },
    "backgroundPanel": {
      "dark": "blackL4",
      "light": "whiteL2"
    },
    "backgroundElement": {
      "dark": "blackL3",
      "light": "whiteL3"
    },
    "border": {
      "dark": "blackL2",
      "light": "whiteL4"
    },
    "borderActive": {
      "dark": "bay",
      "light": "bay"
    },
    "borderSubtle": {
      "dark": "blackL3",
      "light": "whiteL3"
    },
    "diffAdded": {
      "dark": "jadeL2",
      "light": "jadeL3"
    },
    "diffRemoved": {
      "dark": "f5Red",
      "light": "f5RedL3"
    },
    "diffContext": {
      "dark": "blackL2",
      "light": "blackL2"
    },
    "diffHunkHeader": {
      "dark": "blackL2",
      "light": "blackL2"
    },
    "diffHighlightAdded": {
      "dark": "jadeL2",
      "light": "jadeL3"
    },
    "diffHighlightRemoved": {
      "dark": "f5Red",
      "light": "f5RedL3"
    },
    "diffAddedBg": {
      "dark": "#0d2614",
      "light": "#d5f0dc"
    },
    "diffRemovedBg": {
      "dark": "#2e0a0f",
      "light": "#fce4e8"
    },
    "diffContextBg": {
      "dark": "blackL4",
      "light": "whiteL2"
    },
    "diffLineNumber": {
      "dark": "blackL3",
      "light": "whiteL4"
    },
    "diffAddedLineNumberBg": {
      "dark": "#0d2614",
      "light": "#c5e0cc"
    },
    "diffRemovedLineNumberBg": {
      "dark": "#2e0a0f",
      "light": "#ecd4d8"
    },
    "markdownText": {
      "dark": "whiteL1",
      "light": "#1a1a1a"
    },
    "markdownHeading": {
      "dark": "eggplantL2",
      "light": "eggplant"
    },
    "markdownLink": {
      "dark": "bayL2",
      "light": "bayL3"
    },
    "markdownLinkText": {
      "dark": "f5Red",
      "light": "f5RedL3"
    },
    "markdownCode": {
      "dark": "jadeL2",
      "light": "jadeL3"
    },
    "markdownBlockQuote": {
      "dark": "blackL2",
      "light": "blackL2"
    },
    "markdownEmph": {
      "dark": "tangerineL2",
      "light": "tangerineL3"
    },
    "markdownStrong": {
      "dark": "tangerine",
      "light": "tangerineL3"
    },
    "markdownHorizontalRule": {
      "dark": "blackL1",
      "light": "blackL2"
    },
    "markdownListItem": {
      "dark": "bayL2",
      "light": "bayL3"
    },
    "markdownListEnumeration": {
      "dark": "eggplantL2",
      "light": "eggplant"
    },
    "markdownImage": {
      "dark": "bayL2",
      "light": "bayL3"
    },
    "markdownImageText": {
      "dark": "f5Red",
      "light": "f5RedL3"
    },
    "markdownCodeBlock": {
      "dark": "whiteL1",
      "light": "#1a1a1a"
    },
    "syntaxComment": {
      "dark": "#5c6370",
      "light": "#6c7086"
    },
    "syntaxKeyword": {
      "dark": "#c678dd",
      "light": "#7c3aed"
    },
    "syntaxFunction": {
      "dark": "#61afef",
      "light": "#0062d1"
    },
    "syntaxVariable": {
      "dark": "#e06c75",
      "light": "#dc2626"
    },
    "syntaxString": {
      "dark": "#98c379",
      "light": "#16a34a"
    },
    "syntaxNumber": {
      "dark": "#d19a66",
      "light": "#d97706"
    },
    "syntaxType": {
      "dark": "#e5c07b",
      "light": "#d97706"
    },
    "syntaxOperator": {
      "dark": "#56b6c2",
      "light": "#0891b2"
    },
    "syntaxPunctuation": {
      "dark": "#abb2bf",
      "light": "#45475a"
    }
  }
}
